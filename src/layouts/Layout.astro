---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} - Support Your Local First Responders</title>
	</head>
	<body class="circuit-pattern min-h-screen">
		<slot />
	</body>
</html>
