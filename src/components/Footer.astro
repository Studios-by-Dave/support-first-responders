---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark border-t border-brand-light/30 py-8 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h4 class="text-lg font-semibold text-brand-light mb-4">Shelby Web Co.</h4>
        <p class="text-gray-400 text-sm">
          Supporting our community's heroes through technology and awareness
        </p>
      </div>
      
      <div>
        <h4 class="text-lg font-semibold text-brand-light mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#statistics" class="text-gray-400 hover:text-brand-accent transition-colors">Statistics</a></li>
          <li><a href="#organizations" class="text-gray-400 hover:text-brand-accent transition-colors">Organizations</a></li>
          <li><a href="#resources" class="text-gray-400 hover:text-brand-accent transition-colors">Resources</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-lg font-semibold text-brand-light mb-4">Emergency</h4>
        <p class="text-gray-400 text-sm mb-2">In an emergency, always dial:</p>
        <p class="text-3xl font-bold text-brand-accent">911</p>
      </div>
    </div>
    
    <div class="border-t border-brand-light/20 pt-6 text-center">
      <p class="text-gray-500 text-sm">
        © {currentYear} Shelby Web Co. All rights reserved. | 
        <a href="https://www.shelbywebco.com" target="_blank" rel="noopener" class="text-brand-accent hover:text-white transition-colors">www.shelbywebco.com</a>
      </p>
    </div>
  </div>
</footer>
